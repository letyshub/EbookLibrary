<UserControl x:Class="EbookLibrary.Views.AddView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:cal="http://www.caliburnproject.org"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource MaterialDesignPaper}"
             FontFamily="{DynamicResource MaterialDesignFont}"
             mc:Ignorable="d"
             d:DesignHeight="680" d:DesignWidth="960">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <materialDesign:ColorZone Mode="PrimaryMid" Grid.Row="0" Padding="16,14">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="BookPlus" Width="26" Height="26"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="White"/>
                <TextBlock Text="{DynamicResource String.AddEbookHeader}" FontSize="20" FontWeight="Medium"
                           Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </materialDesign:ColorZone>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <materialDesign:Card Margin="24,20,24,8" Padding="28,20">
                <StackPanel>
                    <!-- Title -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <materialDesign:PackIcon Kind="BookOutline" Width="20" Height="20"
                                                 VerticalAlignment="Bottom" Margin="0,0,8,4"
                                                 Opacity="0.6"/>
                        <TextBox x:Name="Title"
                                 materialDesign:HintAssist.Hint="{DynamicResource String.Title}"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 FontSize="16" Width="800" HorizontalAlignment="Left">
                            <TextBox.Text>
                                <Binding Path="Title" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <el:RequiredRule ValidatesOnTargetUpdated="False"
                                                         ValidationStep="UpdatedValue"
                                                         xmlns:el="clr-namespace:EbookLibrary"/>
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>
                    </StackPanel>

                    <!-- Author -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                        <materialDesign:PackIcon Kind="AccountOutline" Width="20" Height="20"
                                                 VerticalAlignment="Bottom" Margin="0,0,8,4"
                                                 Opacity="0.6"/>
                        <TextBox x:Name="Author"
                                 materialDesign:HintAssist.Hint="{DynamicResource String.Author}"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 FontSize="16" Width="800" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Path -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                        <materialDesign:PackIcon Kind="FilePdfBox" Width="20" Height="20"
                                                 VerticalAlignment="Bottom" Margin="0,0,8,4"
                                                 Opacity="0.6"/>
                        <TextBox x:Name="Path"
                                 materialDesign:HintAssist.Hint="{DynamicResource String.FilePath}"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 FontSize="16" Width="700">
                            <TextBox.Text>
                                <Binding Path="Path" UpdateSourceTrigger="PropertyChanged"
                                         Mode="TwoWay" ValidatesOnDataErrors="True">
                                    <Binding.ValidationRules>
                                        <el:RequiredRule ValidatesOnTargetUpdated="False"
                                                         ValidationStep="UpdatedValue"
                                                         xmlns:el="clr-namespace:EbookLibrary"/>
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>
                        <Button cal:Message.Attach="SelectFile"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="{DynamicResource String.SelectFile}" Margin="4,0,0,0">
                            <materialDesign:PackIcon Kind="FolderOpen" Width="20" Height="20"/>
                        </Button>
                        <Button cal:Message.Attach="OpenFile"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="{DynamicResource String.OpenFile}" Cursor="Hand">
                            <materialDesign:PackIcon Kind="BookOpenVariant" Width="20" Height="20"/>
                        </Button>
                    </StackPanel>

                    <!-- Tags -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                        <materialDesign:PackIcon Kind="TagOutline" Width="20" Height="20"
                                                 VerticalAlignment="Bottom" Margin="0,0,8,4"
                                                 Opacity="0.6"/>
                        <TextBox x:Name="Tags"
                                 materialDesign:HintAssist.Hint="{DynamicResource String.Tags}"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 FontSize="16" Width="800" HorizontalAlignment="Left"/>
                    </StackPanel>

                </StackPanel>
            </materialDesign:Card>
        </ScrollViewer>

        <!-- Metadata loading overlay -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
            <Border Background="{DynamicResource MaterialDesignPaper}" Opacity="0.82"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                             IsIndeterminate="True"
                             Width="48" Height="48"
                             HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource String.ReadingMetadata}"
                           Margin="0,12,0,0"
                           HorizontalAlignment="Center"
                           Opacity="0.7" FontSize="13"/>
            </StackPanel>
        </Grid>

        <!-- Action buttons -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button cal:Message.Attach="Cancel"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource String.Cancel}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="Save"
                        cal:Message.Attach="Save"
                        Style="{StaticResource MaterialDesignRaisedButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource String.Save}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
