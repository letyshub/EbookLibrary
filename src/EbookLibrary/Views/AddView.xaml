<UserControl x:Class="EbookLibrary.Views.AddView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:cal="http://www.caliburnproject.org"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource MaterialDesignPaper}"
             FontFamily="{DynamicResource MaterialDesignFont}"
             mc:Ignorable="d"
             d:DesignHeight="680" d:DesignWidth="960">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <materialDesign:ColorZone Mode="PrimaryMid" Grid.Row="0" Padding="16,14">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="BookPlus" Width="26" Height="26"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="White"/>
                <TextBlock Text="Dodaj ebook" FontSize="20" FontWeight="Medium"
                           Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </materialDesign:ColorZone>

        <!-- Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <materialDesign:Card Margin="24,20,24,8" Padding="28,20">
                <StackPanel>
                    <!-- Title -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <materialDesign:PackIcon Kind="BookOutline" Width="20" Height="20"
                                                 VerticalAlignment="Bottom" Margin="0,0,8,4"
                                                 Opacity="0.6"/>
                        <TextBox x:Name="Title"
                                 materialDesign:HintAssist.Hint="Tytuł"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 FontSize="16" Width="800" HorizontalAlignment="Left">
                            <TextBox.Text>
                                <Binding Path="Title" UpdateSourceTrigger="PropertyChanged">
                                    <Binding.ValidationRules>
                                        <el:RequiredRule ValidatesOnTargetUpdated="False"
                                                         ValidationStep="UpdatedValue"
                                                         xmlns:el="clr-namespace:EbookLibrary"/>
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>
                    </StackPanel>

                    <!-- Author -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                        <materialDesign:PackIcon Kind="AccountOutline" Width="20" Height="20"
                                                 VerticalAlignment="Bottom" Margin="0,0,8,4"
                                                 Opacity="0.6"/>
                        <TextBox x:Name="Author"
                                 materialDesign:HintAssist.Hint="Autor"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 FontSize="16" Width="800" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Path -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                        <materialDesign:PackIcon Kind="FilePdfBox" Width="20" Height="20"
                                                 VerticalAlignment="Bottom" Margin="0,0,8,4"
                                                 Opacity="0.6"/>
                        <TextBox x:Name="Path"
                                 materialDesign:HintAssist.Hint="Ścieżka do pliku"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 FontSize="16" Width="700">
                            <TextBox.Text>
                                <Binding Path="Path" UpdateSourceTrigger="PropertyChanged"
                                         Mode="TwoWay" ValidatesOnDataErrors="True">
                                    <Binding.ValidationRules>
                                        <el:RequiredRule ValidatesOnTargetUpdated="False"
                                                         ValidationStep="UpdatedValue"
                                                         xmlns:el="clr-namespace:EbookLibrary"/>
                                    </Binding.ValidationRules>
                                </Binding>
                            </TextBox.Text>
                        </TextBox>
                        <Button cal:Message.Attach="SelectFile"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="Wybierz plik" Margin="4,0,0,0">
                            <materialDesign:PackIcon Kind="FolderOpen" Width="20" Height="20"/>
                        </Button>
                        <Button cal:Message.Attach="OpenFile"
                                Style="{StaticResource MaterialDesignIconButton}"
                                ToolTip="Otwórz ebook" Cursor="Hand">
                            <materialDesign:PackIcon Kind="BookOpenVariant" Width="20" Height="20"/>
                        </Button>
                    </StackPanel>

                    <!-- Tags -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                        <materialDesign:PackIcon Kind="TagOutline" Width="20" Height="20"
                                                 VerticalAlignment="Bottom" Margin="0,0,8,4"
                                                 Opacity="0.6"/>
                        <TextBox x:Name="Tags"
                                 materialDesign:HintAssist.Hint="Tagi (oddzielone przecinkiem)"
                                 Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                                 FontSize="16" Width="800" HorizontalAlignment="Left"/>
                    </StackPanel>

                    <!-- Priority -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,4">
                        <materialDesign:PackIcon Kind="Flag" Width="20" Height="20"
                                                 VerticalAlignment="Bottom" Margin="0,0,8,4"
                                                 Opacity="0.6"/>
                        <ComboBox x:Name="Priority"
                                  materialDesign:HintAssist.Hint="Priorytet"
                                  Style="{StaticResource MaterialDesignFloatingHintComboBox}"
                                  FontSize="16" Width="300" HorizontalAlignment="Left"
                                  SelectedValue="{Binding Priority}" SelectedValuePath="Tag">
                            <ComboBoxItem Content="Brak" Tag="0"/>
                            <ComboBoxItem Content="Niski" Tag="1"/>
                            <ComboBoxItem Content="Średni" Tag="2"/>
                            <ComboBoxItem Content="Wysoki" Tag="3"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- IsRead -->
                    <StackPanel Orientation="Horizontal" Margin="0,16,0,4">
                        <materialDesign:PackIcon Kind="BookCheck" Width="20" Height="20"
                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                 Opacity="0.6"/>
                        <CheckBox x:Name="IsRead"
                                  Content="Oznacz jako przeczytaną"
                                  IsChecked="{Binding IsRead}"
                                  FontSize="14"
                                  Style="{StaticResource MaterialDesignCheckBox}"/>
                    </StackPanel>
                </StackPanel>
            </materialDesign:Card>
        </ScrollViewer>

        <!-- Action buttons -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button cal:Message.Attach="Cancel"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Anuluj" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="Save"
                        cal:Message.Attach="Save"
                        Style="{StaticResource MaterialDesignRaisedButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Zapisz" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
