<UserControl x:Class="EbookLibrary.Views.ReadingListDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:cal="http://www.caliburnproject.org"
             Background="{DynamicResource MaterialDesignPaper}"
             FontFamily="{DynamicResource MaterialDesignFont}"
             mc:Ignorable="d"
             d:DesignHeight="680" d:DesignWidth="960">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <materialDesign:ColorZone Mode="PrimaryMid" Grid.Row="0" Padding="16,14">
            <DockPanel>
                <Button DockPanel.Dock="Left"
                        Style="{StaticResource MaterialDesignIconForegroundButton}"
                        cal:Message.Attach="Back"
                        ToolTip="{DynamicResource String.Back}"
                        Foreground="White">
                    <materialDesign:PackIcon Kind="ArrowLeft" Width="24" Height="24"/>
                </Button>
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource MaterialDesignIconForegroundButton}"
                        cal:Message.Attach="ShowAddBook"
                        ToolTip="{DynamicResource String.AddBook}"
                        Foreground="White">
                    <materialDesign:PackIcon Kind="BookPlus" Width="24" Height="24"/>
                </Button>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <materialDesign:PackIcon Kind="FormatListChecks" Width="28" Height="28"
                                            VerticalAlignment="Center" Margin="0,0,10,0"
                                            Foreground="White"/>
                    <TextBlock Text="{Binding ListName}" FontSize="20" FontWeight="Medium"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </materialDesign:ColorZone>

        <!-- Add book search panel -->
        <Border Grid.Row="1"
                Background="{DynamicResource MaterialDesignToolBarBackground}"
                BorderThickness="0,0,0,1" BorderBrush="{DynamicResource MaterialDesignDivider}"
                Visibility="{Binding IsAddingBook, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <!-- Search row -->
                <DockPanel Margin="12,8">
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource MaterialDesignFlatButton}"
                            cal:Message.Attach="HideAddBook"
                            Margin="4,0,0,0">
                        <TextBlock Text="{DynamicResource String.Cancel}"/>
                    </Button>
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource MaterialDesignIconButton}"
                            cal:Message.Attach="SearchBooks">
                        <materialDesign:PackIcon Kind="Magnify"/>
                    </Button>
                    <TextBox x:Name="SearchQuery"
                             materialDesign:HintAssist.Hint="{DynamicResource String.SearchBooksHint}"
                             Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                             VerticalAlignment="Center" FontSize="14"
                             cal:Message.Attach="[Event KeyDown] = [Action SearchBooks()]"/>
                </DockPanel>
                <!-- Search results -->
                <ItemsControl ItemsSource="{Binding SearchResults}" MaxHeight="200">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderThickness="0,1,0,0"
                                    BorderBrush="{DynamicResource MaterialDesignDivider}"
                                    Padding="16,8">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right"
                                            Style="{StaticResource MaterialDesignFlatButton}"
                                            cal:Message.Attach="[Event Click] = [Action AddBook($this)]">
                                        <TextBlock Text="{DynamicResource String.Add}"/>
                                    </Button>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontWeight="Medium"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Author}"
                                                   Style="{StaticResource MaterialDesignBody2TextBlock}"
                                                   Opacity="0.65"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Book list -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Items}" Margin="16,10,16,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Margin="0,5,0,5" Padding="0">
                            <DockPanel>
                                <!-- Left accent strip colored by priority -->
                                <Border DockPanel.Dock="Left" Width="5">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource MaterialDesignDivider}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Priority}" Value="1">
                                                    <Setter Property="Background" Value="#4CAF50"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Priority}" Value="2">
                                                    <Setter Property="Background" Value="#FF9800"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Priority}" Value="3">
                                                    <Setter Property="Background" Value="#F44336"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <DockPanel Margin="14,12,6,12">
                                    <!-- Action buttons -->
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                cal:Message.Attach="[Event Click] = [Action OpenEbook($this)]"
                                                ToolTip="{DynamicResource String.OpenEbook}"
                                                Foreground="{DynamicResource PrimaryHueMidBrush}">
                                            <materialDesign:PackIcon Kind="BookOpenVariant" Width="20" Height="20"/>
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                cal:Message.Attach="[Event Click] = [Action CyclePriority($this)]"
                                                ToolTip="{DynamicResource String.ChangePriority}">
                                            <materialDesign:PackIcon Kind="Flag" Width="18" Height="18">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Priority}" Value="1">
                                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Priority}" Value="2">
                                                                <Setter Property="Foreground" Value="#E65100"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Priority}" Value="3">
                                                                <Setter Property="Foreground" Value="#C62828"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                cal:Message.Attach="[Event Click] = [Action RemoveEntry($this)]"
                                                ToolTip="{DynamicResource String.RemoveFromList}">
                                            <materialDesign:PackIcon Kind="BookmarkRemove" Width="18" Height="18"/>
                                        </Button>
                                    </StackPanel>

                                    <!-- Book info -->
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="15" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,6">
                                            <materialDesign:PackIcon Kind="AccountOutline"
                                                                     Width="14" Height="14"
                                                                     VerticalAlignment="Center"
                                                                     Opacity="0.55" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Author}"
                                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                                       Opacity="0.65" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Priority badge -->
                                        <Border CornerRadius="10" Padding="8,2" Margin="0,0,0,0" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Priority}" Value="1">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Setter Property="Background" Value="#E8F5E9"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Priority}" Value="2">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Setter Property="Background" Value="#FFF3E0"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Priority}" Value="3">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Setter Property="Background" Value="#FFEBEE"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Flag" Width="11" Height="11"
                                                                         VerticalAlignment="Center" Margin="0,0,3,0">
                                                    <materialDesign:PackIcon.Style>
                                                        <Style TargetType="materialDesign:PackIcon">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Priority}" Value="1">
                                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Priority}" Value="2">
                                                                    <Setter Property="Foreground" Value="#E65100"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Priority}" Value="3">
                                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </materialDesign:PackIcon.Style>
                                                </materialDesign:PackIcon>
                                                <TextBlock FontSize="11" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Priority}" Value="1">
                                                                    <Setter Property="Text" Value="{DynamicResource String.PriorityLow}"/>
                                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Priority}" Value="2">
                                                                    <Setter Property="Text" Value="{DynamicResource String.PriorityMedium}"/>
                                                                    <Setter Property="Foreground" Value="#E65100"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Priority}" Value="3">
                                                                    <Setter Property="Text" Value="{DynamicResource String.PriorityHigh}"/>
                                                                    <Setter Property="Foreground" Value="#C62828"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </DockPanel>
                            </DockPanel>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
