<UserControl x:Class="EbookLibrary.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:cal="http://www.caliburnproject.org"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource MaterialDesignPaper}"
             FontFamily="{DynamicResource MaterialDesignFont}"
             mc:Ignorable="d"
             d:DesignHeight="680" d:DesignWidth="960">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <materialDesign:ColorZone Mode="PrimaryMid" Grid.Row="0" Padding="16,14">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="Cog" Width="26" Height="26"
                                         VerticalAlignment="Center" Margin="0,0,10,0"
                                         Foreground="White"/>
                <TextBlock Text="{DynamicResource String.SettingsHeader}" FontSize="20" FontWeight="Medium"
                           Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </materialDesign:ColorZone>

        <!-- Settings card -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <materialDesign:Card Margin="24,20,24,8" Padding="28,24" HorizontalAlignment="Left" MinWidth="400">
                <StackPanel>

                    <!-- Language section -->
                    <TextBlock Text="{DynamicResource String.Language}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="4,0,0,0">
                        <RadioButton GroupName="Language"
                                     IsChecked="{Binding IsPolish, Mode=TwoWay}"
                                     Content="{DynamicResource String.Polish}"
                                     Style="{StaticResource MaterialDesignRadioButton}"
                                     Margin="0,0,24,0"/>
                        <RadioButton GroupName="Language"
                                     IsChecked="{Binding IsEnglish, Mode=TwoWay}"
                                     Content="{DynamicResource String.English}"
                                     Style="{StaticResource MaterialDesignRadioButton}"/>
                    </StackPanel>

                    <Separator Margin="0,20,0,20"/>

                    <!-- Theme section -->
                    <TextBlock Text="{DynamicResource String.Theme}"
                               Style="{StaticResource MaterialDesignSubtitle1TextBlock}"
                               Margin="0,0,0,12"/>
                    <StackPanel Orientation="Horizontal" Margin="4,0,0,0">
                        <RadioButton GroupName="Theme"
                                     IsChecked="{Binding IsLightTheme, Mode=TwoWay}"
                                     Content="{DynamicResource String.ThemeLight}"
                                     Style="{StaticResource MaterialDesignRadioButton}"
                                     Margin="0,0,24,0"/>
                        <RadioButton GroupName="Theme"
                                     IsChecked="{Binding IsDarkTheme, Mode=TwoWay}"
                                     Content="{DynamicResource String.ThemeDark}"
                                     Style="{StaticResource MaterialDesignRadioButton}"/>
                    </StackPanel>

                </StackPanel>
            </materialDesign:Card>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Button cal:Message.Attach="Back"
                        Style="{StaticResource MaterialDesignFlatButton}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{DynamicResource String.Back}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
