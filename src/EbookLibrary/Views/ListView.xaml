<UserControl x:Class="EbookLibrary.Views.ListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:cal="http://www.caliburnproject.org"
             Background="{DynamicResource MaterialDesignPaper}"
             FontFamily="{DynamicResource MaterialDesignFont}"
             mc:Ignorable="d"
             d:DesignHeight="680" d:DesignWidth="960">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <materialDesign:ColorZone Mode="PrimaryMid" Grid.Row="0" Padding="16,14">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                            cal:Message.Attach="Settings"
                            ToolTip="{DynamicResource String.Settings}"
                            Foreground="White">
                        <materialDesign:PackIcon Kind="Cog" Width="24" Height="24"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                            cal:Message.Attach="ReadingLists"
                            ToolTip="{DynamicResource String.ReadingLists}"
                            Foreground="White">
                        <materialDesign:PackIcon Kind="FormatListChecks" Width="24" Height="24"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                            cal:Message.Attach="AddEbook"
                            ToolTip="{DynamicResource String.AddEbook}"
                            Foreground="White">
                        <materialDesign:PackIcon Kind="BookPlus" Width="24" Height="24"/>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="BookMultiple" Width="28" Height="28"
                                            VerticalAlignment="Center" Margin="0,0,10,0"
                                            Foreground="White"/>
                    <TextBlock Text="{DynamicResource String.AppTitle}" FontSize="20" FontWeight="Medium"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
            </DockPanel>
        </materialDesign:ColorZone>

        <!-- Search bar -->
        <Border Grid.Row="1" Background="{DynamicResource MaterialDesignToolBarBackground}"
                BorderThickness="0,0,0,1" BorderBrush="{DynamicResource MaterialDesignDivider}"
                Padding="12,6">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource MaterialDesignIconButton}"
                        cal:Message.Attach="SearchEbook"
                        ToolTip="{DynamicResource String.Search}">
                    <materialDesign:PackIcon Kind="Magnify"/>
                </Button>
                <materialDesign:PackIcon Kind="Magnify" VerticalAlignment="Center"
                                         Margin="4,0,8,0" Opacity="0.45" Width="18" Height="18"/>
                <TextBox x:Name="Query"
                         materialDesign:HintAssist.Hint="{DynamicResource String.SearchHint}"
                         Style="{StaticResource MaterialDesignFloatingHintTextBox}"
                         VerticalAlignment="Center" FontSize="14"
                         cal:Message.Attach="[Event KeyDown] = [Action SearchEbook()]"/>
            </DockPanel>
        </Border>

        <!-- Filter bar -->
        <Border Grid.Row="2" Background="{DynamicResource MaterialDesignToolBarBackground}"
                BorderThickness="0,0,0,1" BorderBrush="{DynamicResource MaterialDesignDivider}"
                Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <Button cal:Message.Attach="ShowAll"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Margin="0,0,4,0" Padding="12,4">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Check" Width="14" Height="14"
                                                 VerticalAlignment="Center" Margin="0,0,4,0"
                                                 Visibility="{Binding IsFilterAll, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{DynamicResource String.FilterAll}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button cal:Message.Attach="ShowToRead"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Margin="0,0,4,0" Padding="12,4">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Check" Width="14" Height="14"
                                                 VerticalAlignment="Center" Margin="0,0,4,0"
                                                 Visibility="{Binding IsFilterToRead, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{DynamicResource String.FilterToRead}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button cal:Message.Attach="ShowRead"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Margin="0,0,4,0" Padding="12,4">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Check" Width="14" Height="14"
                                                 VerticalAlignment="Center" Margin="0,0,4,0"
                                                 Visibility="{Binding IsFilterRead, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{DynamicResource String.FilterRead}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Book list -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
            <ItemsControl ItemsSource="{Binding Ebooks}" Margin="16,10,16,16">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <materialDesign:Card Margin="0,5,0,5" Padding="0">
                            <DockPanel>
                                <!-- Left accent strip — green if read, primary if unread -->
                                <Border DockPanel.Dock="Left" Width="5">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                    <Setter Property="Background" Value="#4CAF50"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <!-- Content -->
                                <DockPanel Margin="14,12,6,12">
                                    <!-- Action buttons (right side) -->
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <!-- Toggle read/unread -->
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                cal:Message.Attach="[Event Click] = [Action ToggleRead($this)]"
                                                ToolTip="{DynamicResource String.ToggleReadTooltip}">
                                            <materialDesign:PackIcon Width="20" Height="20">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Kind" Value="BookOutline"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBody}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                                <Setter Property="Kind" Value="BookCheck"/>
                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                cal:Message.Attach="[Event Click] = [Action OpenEbook($this)]"
                                                ToolTip="{DynamicResource String.OpenEbook}"
                                                Foreground="{DynamicResource PrimaryHueMidBrush}">
                                            <materialDesign:PackIcon Kind="BookOpenVariant" Width="20" Height="20"/>
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                cal:Message.Attach="[Event Click] = [Action AddToList($this)]"
                                                ToolTip="{DynamicResource String.AddToList}">
                                            <materialDesign:PackIcon Kind="BookmarkPlus" Width="18" Height="18"/>
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                                cal:Message.Attach="[Event Click] = [Action EditEbook($this)]"
                                                ToolTip="{DynamicResource String.Edit}">
                                            <materialDesign:PackIcon Kind="Pencil" Width="18" Height="18"/>
                                        </Button>
                                    </StackPanel>

                                    <!-- Book info -->
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="15" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,6">
                                            <materialDesign:PackIcon Kind="AccountOutline"
                                                                     Width="14" Height="14"
                                                                     VerticalAlignment="Center"
                                                                     Opacity="0.55" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding Author}"
                                                       Style="{StaticResource MaterialDesignBody2TextBlock}"
                                                       Opacity="0.65" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <!-- Tags and priority row -->
                                        <WrapPanel>
                                            <!-- Priority badge (hidden when Priority = 0) -->
                                            <Border CornerRadius="10" Padding="8,2" Margin="0,0,6,2">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Priority}" Value="1">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Priority}" Value="2">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Setter Property="Background" Value="#FFF3E0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Priority}" Value="3">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                <Setter Property="Background" Value="#FFEBEE"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Flag" Width="11" Height="11"
                                                                             VerticalAlignment="Center" Margin="0,0,3,0">
                                                        <materialDesign:PackIcon.Style>
                                                            <Style TargetType="materialDesign:PackIcon">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Priority}" Value="1">
                                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Priority}" Value="2">
                                                                        <Setter Property="Foreground" Value="#E65100"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Priority}" Value="3">
                                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </materialDesign:PackIcon.Style>
                                                    </materialDesign:PackIcon>
                                                    <TextBlock FontSize="11" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Priority}" Value="1">
                                                                        <Setter Property="Text" Value="{DynamicResource String.PriorityLow}"/>
                                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Priority}" Value="2">
                                                                        <Setter Property="Text" Value="{DynamicResource String.PriorityMedium}"/>
                                                                        <Setter Property="Foreground" Value="#E65100"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Priority}" Value="3">
                                                                        <Setter Property="Text" Value="{DynamicResource String.PriorityHigh}"/>
                                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>

                                            <!-- Tag pills -->
                                            <ItemsControl ItemsSource="{Binding Tags}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource PrimaryHueLightBrush}"
                                                                CornerRadius="10" Padding="8,2" Margin="0,0,5,2">
                                                            <StackPanel Orientation="Horizontal">
                                                                <materialDesign:PackIcon Kind="Tag"
                                                                                         Width="11" Height="11"
                                                                                         VerticalAlignment="Center"
                                                                                         Foreground="{DynamicResource PrimaryHueLightForegroundBrush}"
                                                                                         Margin="0,0,3,0"/>
                                                                <TextBlock Text="{Binding}"
                                                                           Foreground="{DynamicResource PrimaryHueLightForegroundBrush}"
                                                                           FontSize="11" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                        </WrapPanel>
                                    </StackPanel>
                                </DockPanel>
                            </DockPanel>
                        </materialDesign:Card>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status bar -->
        <Border Grid.Row="4"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource MaterialDesignDivider}"
                Background="{DynamicResource MaterialDesignToolBarBackground}"
                Padding="16,5">
            <TextBlock Text="{Binding CountInfo}"
                       FontSize="12" Opacity="0.55"
                       HorizontalAlignment="Right"/>
        </Border>
    </Grid>
</UserControl>
