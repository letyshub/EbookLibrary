    <sys:String x:Key="String.SettingsHeader">Ustawienia</sys:String>
    <sys:String x:Key="String.Language">Język</sys:String>
    <sys:String x:Key="String.Polish">Polski</sys:String>
    <sys:String x:Key="String.English">English</sys:String>
    <sys:String x:Key="String.Theme">Motyw</sys:String>
    <sys:String x:Key="String.ThemeLight">Jasny</sys:String>
    <sys:String x:Key="String.ThemeDark">Ciemny</sys:String>
    <sys:String x:Key="String.Back">Powrót</sys:String>

