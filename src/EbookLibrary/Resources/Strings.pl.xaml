    <sys:String x:Key="String.ReadingLists">Listy do przeczytania</sys:String>
    <sys:String x:Key="String.AddToList">Dodaj do listy</sys:String>
    <sys:String x:Key="String.NewListHint">Nazwa nowej listy...</sys:String>
