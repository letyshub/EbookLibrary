    <sys:String x:Key="String.PriorityNone">Brak</sys:String>
    <sys:String x:Key="String.MarkAsRead">Oznacz jako przeczytaną</sys:String>
    <sys:String x:Key="String.Cancel">Anuluj</sys:String>
    <sys:String x:Key="String.Save">Zapisz</sys:String>
    <sys:String x:Key="String.Delete">Usuń</sys:String>
    <sys:String x:Key="String.Open">Otwórz</sys:String>

    <!-- Confirmation dialog -->
    <sys:String x:Key="String.ConfirmationTitle">Potwierdzenie</sys:String>
    <sys:String x:Key="String.No">Nie</sys:String>
